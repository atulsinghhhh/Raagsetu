{
  "expo": {
    "name": "Raagsetu",
    "slug": "Raagsetu",
    "version": "1.0.0",

    "orientation": "portrait",
    "scheme": "raagsetu",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0D0014",

    "icon": "./assets/images/1_app_icon_512.png",

    "splash": {
      "image": "./assets/images/2_splash_logo_540x960.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0014"
    },

    "assetBundlePatterns": ["**/*"],

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "jsEngine": "hermes",

    "ios": {
      "bundleIdentifier": "com.atulsinghh.raagsetu",
      "buildNumber": "1",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSPhotoLibraryUsageDescription": "Raagsetu uses your photo library to set playlist cover images.",
        "NSMicrophoneUsageDescription": "Raagsetu needs microphone access for voice search.",
        "CFBundleAllowMixedLocalizations": true
      }
    },

    "android": {
      "package": "com.atulsinghh.raagsetu",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/3_adaptive_foreground_512.png",
        "backgroundColor": "#0D0014"
      },
      "permissions": [
        "INTERNET",
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_IMAGES",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/1_app_icon_512.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-sharing",
        {
          "ios": { "enabled": true },
          "android": {
            "enabled": true,
            "singleShareMimeTypes": ["audio/*"],
            "multipleShareMimeTypes": ["audio/*"]
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "956f7e75-8993-48ad-ae8f-16c4ff55b74b"
      }
    },

    "owner": "atulsinghh"
  }
}